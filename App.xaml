<Application x:Class="XTSPrimeMoverProject.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:XTSPrimeMoverProject"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Runtime gateway toggle: true = RemoteTwinCatMachineGatewayMock, false = LocalSimulationServiceGateway -->
        <sys:Boolean x:Key="UseRemoteTwinCatMachineGatewayMock">True</sys:Boolean>

        <!-- Applied only when remote mock is enabled -->
        <sys:Int32 x:Key="RemoteTwinCatMachineGatewayMockLatencyMs">40</sys:Int32>
    </Application.Resources>
</Application>
