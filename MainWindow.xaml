<Window x:Class="XTSPrimeMoverProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XTSPrimeMoverProject"
        mc:Ignorable="d"
        Title="Beckhoff XTS Prime Mover System" Height="900" Width="1400"
        Background="#1E1E1E">
    <Window.Resources>
        <local:MoverPositionConverter x:Key="MoverPositionConverter"/>
        <local:MoverColorConverter x:Key="MoverColorConverter"/>
        <local:StationRotaryPositionConverter x:Key="StationRotaryPositionConverter"/>
        <local:StationStateBrushConverter x:Key="StationStateBrushConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:StringToBrushConverter x:Key="StringToBrushConverter"/>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5,2"/>
        </Style>
        
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1F1F20"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#F0F0F0"/>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1F1F20"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DarkTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
        </Style>

        <Style x:Key="DarkTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4,4,0,0"
                                Margin="1,1,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1F1F20"/>
                                <Setter Property="Foreground" Value="#FFD700"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#333337"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#1F1F20"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#1F1F20"/>
            <Setter Property="AlternatingRowBackground" Value="#252526"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3F3F46"/>
            <Setter Property="VerticalGridLinesBrush" Value="#3F3F46"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2D2D30"/>
                        <Setter Property="Foreground" Value="#E6E6E6"/>
                        <Setter Property="BorderBrush" Value="#3F3F46"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="6,4"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="#1F1F20"/>
                        <Setter Property="Foreground" Value="#F0F0F0"/>
                        <Setter Property="BorderBrush" Value="#3F3F46"/>
                        <Setter Property="BorderThickness" Value="0.5"/>
                        <Setter Property="Padding" Value="4,2"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#1F1F20"/>
                        <Setter Property="Foreground" Value="#F0F0F0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#094771"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════
             MACHINE DETAIL TAB – reusable DataTemplate
             DataContext = MachineViewModel
        ════════════════════════════════════════════════ -->
        <DataTemplate x:Key="MachineDetailTemplate">
            <ScrollViewer Background="#1A1A1C"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- machine header banner -->
                        <RowDefinition Height="Auto"/>
                        <!-- rotary + KPI side-by-side -->
                        <RowDefinition Height="Auto"/>
                        <!-- station flow strip -->
                        <RowDefinition Height="Auto"/>
                        <!-- robot transfer visual -->
                        <RowDefinition Height="Auto"/>
                        <!-- fault / status footer -->
                    </Grid.RowDefinitions>

                    <!-- ── HEADER BANNER ── -->
                    <Border Grid.Row="0" CornerRadius="8" Margin="0,0,0,10" Padding="14,10">
                        <Border.Background>
                            <SolidColorBrush Color="#2D2D30"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <Binding Path="TypeColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>0,0,0,3</Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- icon + name -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TypeIcon, Mode=OneWay}" FontSize="32" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontSize="20" FontWeight="Bold">
                                        <TextBlock.Foreground>
                                            <Binding Path="TypeColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock Text="{Binding TypeDescription, Mode=OneWay}" FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap" MaxWidth="480"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- status badge -->
                            <Border Grid.Column="2" CornerRadius="6" Padding="12,6" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Border.Background>
                                    <Binding Path="StatusBadgeColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                </Border.Background>
                                <TextBlock Text="{Binding StatusBadgeText, Mode=OneWay}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── ROTARY DIAL + KPI PANEL ── -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- large rotary dial -->
                        <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="ROTARY TABLE" Foreground="#9CDCFE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Canvas Width="200" Height="200" HorizontalAlignment="Center">
                                    <!-- outer ring -->
                                    <Ellipse Width="190" Height="190" Canvas.Left="5" Canvas.Top="5" Stroke="#3F3F46" StrokeThickness="3" Fill="#1A1A1C"/>
                                    <!-- accent ring coloured by machine type -->
                                    <Ellipse Width="174" Height="174" Canvas.Left="13" Canvas.Top="13" StrokeThickness="4" Fill="Transparent">
                                        <Ellipse.Stroke>
                                            <Binding Path="TypeColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                        </Ellipse.Stroke>
                                        <Ellipse.Opacity>0.45</Ellipse.Opacity>
                                    </Ellipse>
                                    <!-- inner hub -->
                                    <Ellipse Width="60" Height="60" Canvas.Left="70" Canvas.Top="70" Fill="#2D2D30" Stroke="#5A5A5E" StrokeThickness="2"/>
                                    <TextBlock Canvas.Left="76" Canvas.Top="84" FontSize="10" FontWeight="Bold" Foreground="#FFD700">
                                        <TextBlock.Text><Binding Path="RotaryAngle" Mode="OneWay" StringFormat="{}{0:F0}°"/></TextBlock.Text>
                                    </TextBlock>

                                    <!-- station dots – rotates with RotaryAngle -->
                                    <ItemsControl ItemsSource="{Binding Stations, Mode=OneWay}"
                                                  Width="200" Height="200"
                                                  RenderTransformOrigin="0.5,0.5">
                                        <ItemsControl.RenderTransform>
                                            <RotateTransform Angle="{Binding RotaryAngle, Mode=OneWay}"/>
                                        </ItemsControl.RenderTransform>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style>
                                                <Setter Property="Canvas.Left">
                                                    <Setter.Value>
                                                        <MultiBinding Converter="{StaticResource StationRotaryPositionConverter}" ConverterParameter="X" Mode="OneWay">
                                                            <Binding Path="StationIndex" Mode="OneWay"/>
                                                            <Binding Path="StationCount" Mode="OneWay"/>
                                                        </MultiBinding>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Canvas.Top">
                                                    <Setter.Value>
                                                        <MultiBinding Converter="{StaticResource StationRotaryPositionConverter}" ConverterParameter="Y" Mode="OneWay">
                                                            <Binding Path="StationIndex" Mode="OneWay"/>
                                                            <Binding Path="StationCount" Mode="OneWay"/>
                                                        </MultiBinding>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="22" Height="22" ToolTip="{Binding Name, Mode=OneWay}">
                                                    <Ellipse Width="22" Height="22" Stroke="#E6E6E6" StrokeThickness="1.5">
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush>
                                                                <SolidColorBrush.Color>
                                                                    <MultiBinding Converter="{StaticResource StationStateBrushConverter}" Mode="OneWay">
                                                                        <Binding Path="Status" Mode="OneWay"/>
                                                                        <Binding Path="IsCurrentIndex" Mode="OneWay"/>
                                                                        <Binding Path="HasPart" Mode="OneWay"/>
                                                                    </MultiBinding>
                                                                </SolidColorBrush.Color>
                                                            </SolidColorBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding TypeIcon, Mode=OneWay}" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                                <!-- active station label under dial -->
                                <TextBlock Text="{Binding ActiveStationDescription, Mode=OneWay}" Foreground="#CCCCCC" FontSize="10" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="200" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI cards grid -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- KPI: Parts In -->
                            <Border Grid.Row="0" Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="4" Padding="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="PARTS IN" Foreground="#9CDCFE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PartsEnteredCount, Mode=OneWay}" FontSize="36" FontWeight="Bold" Foreground="#00C875" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- KPI: Parts Out -->
                            <Border Grid.Row="0" Grid.Column="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="4" Padding="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="PARTS OUT" Foreground="#9CDCFE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PartsExitedCount, Mode=OneWay}" FontSize="36" FontWeight="Bold" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- KPI: Efficiency -->
                            <Border Grid.Row="0" Grid.Column="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="4" Padding="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="YIELD" Foreground="#9CDCFE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding EfficiencyText, Mode=OneWay}" FontSize="15" FontWeight="Bold" Foreground="#D7BA7D" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- KPI: PLC State -->
                            <Border Grid.Row="1" Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="4" Padding="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="PLC STATE" Foreground="#9CDCFE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SequencerState, Mode=OneWay}" FontSize="20" FontWeight="Bold" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- KPI: Current part -->
                            <Border Grid.Row="1" Grid.Column="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="4" Padding="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ACTIVE PART" Foreground="#9CDCFE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentPartId, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#CCCCCC" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- KPI: ET/PT -->
                            <Border Grid.Row="1" Grid.Column="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="4" Padding="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="STATION TIMER" Foreground="#9CDCFE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentStationEtPt, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#9CDCFE" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ── STATION FLOW STRIP ── -->
                    <Border Grid.Row="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="STATION PROCESS FLOW" Foreground="#9CDCFE" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Stations, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- single station card -->
                                        <Border Margin="5" Width="210" CornerRadius="10" BorderThickness="2" Padding="10" Background="#25262A">
                                            <Border.BorderBrush>
                                                <Binding Path="StatusBadgeColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                            </Border.BorderBrush>
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.55"
                                                                  Color="{Binding StationCardGlowColor, Mode=OneWay, Converter={StaticResource StringToBrushConverter}}"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- header row: step + name + badge -->
                                                <Grid Grid.Row="0" Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" CornerRadius="4" Padding="5,2" Margin="0,0,6,0" Background="#1F1F20" BorderBrush="#3F3F46" BorderThickness="1">
                                                        <TextBlock Text="{Binding StepIndicatorText, Mode=OneWay}" Foreground="#9CDCFE" FontSize="9" FontWeight="Bold"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TypeIcon, Mode=OneWay}" FontSize="16" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding Name, Mode=OneWay}" FontSize="12" FontWeight="Bold" Foreground="#E6E6E6" TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="2" CornerRadius="4" Padding="5,2" VerticalAlignment="Center" Margin="4,0,0,0">
                                                        <Border.Background>
                                                            <Binding Path="StatusBadgeColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding StatusBadgeText, Mode=OneWay}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>

                                                <!-- station type and active task -->
                                                <TextBlock Grid.Row="1" Text="{Binding TypeDescription, Mode=OneWay}" Foreground="#9A9A9A" FontSize="9" TextWrapping="Wrap"/>

                                                <Border Grid.Row="2" Margin="0,6,0,4" Padding="6,4" Background="#1F1F20" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="{Binding TaskIcon, Mode=OneWay}" FontSize="12" Margin="0,0,5,0"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding CurrentTaskText, Mode=OneWay}" Foreground="#DCDCAA" FontSize="10" TextWrapping="Wrap"/>

                                                        <!-- Tiny animated activity glyphs (only when processing) -->
                                                        <Grid Grid.Column="2" Width="18" Height="18" Margin="6,0,0,0"
                                                              Visibility="{Binding IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <!-- Assembly: rotating gear -->
                                                            <TextBlock Text="⚙" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Type, Mode=OneWay}" Value="Assembly">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <DataTrigger.EnterActions>
                                                                                    <BeginStoryboard x:Name="AssemblyGearPulseStoryboard">
                                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.45" To="1.0" Duration="0:0:0.22"/>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="FontSize" From="11" To="13" Duration="0:0:0.22"/>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </DataTrigger.EnterActions>
                                                                                <DataTrigger.ExitActions>
                                                                                    <StopStoryboard BeginStoryboardName="AssemblyGearPulseStoryboard"/>
                                                                                </DataTrigger.ExitActions>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <!-- Welding: spark pulse -->
                                                            <TextBlock Text="✦" Foreground="#FFD700" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Type, Mode=OneWay}" Value="Welding">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <DataTrigger.EnterActions>
                                                                                    <BeginStoryboard x:Name="WeldingSparkPulseStoryboard">
                                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="1.0" Duration="0:0:0.16"/>
                                                                                            <DoubleAnimation Storyboard.TargetProperty="FontSize" From="10" To="13" Duration="0:0:0.16"/>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </DataTrigger.EnterActions>
                                                                                <DataTrigger.ExitActions>
                                                                                    <StopStoryboard BeginStoryboardName="WeldingSparkPulseStoryboard"/>
                                                                                </DataTrigger.ExitActions>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <!-- Inspection: scanning sweep -->
                                                            <Grid Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Grid.Style>
                                                                    <Style TargetType="Grid">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Type, Mode=OneWay}" Value="Inspection">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>
                                                                <Ellipse Stroke="#9CDCFE" StrokeThickness="1" Fill="Transparent"/>
                                                                <Rectangle Width="2" Height="10" Fill="#9CDCFE" HorizontalAlignment="Center" VerticalAlignment="Center" RadiusX="1" RadiusY="1" Margin="-4,0,0,0">
                                                                    <Rectangle.Triggers>
                                                                        <EventTrigger RoutedEvent="Rectangle.Loaded">
                                                                            <BeginStoryboard>
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                                                       From="-4,0,0,0" To="4,0,0,0" Duration="0:0:0.45"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </Rectangle.Triggers>
                                                                </Rectangle>
                                                            </Grid>

                                                            <!-- Testing: oscillating waveform dot -->
                                                            <Grid Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Grid.Style>
                                                                    <Style TargetType="Grid">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Type, Mode=OneWay}" Value="Testing">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>
                                                                <Rectangle Width="10" Height="1" Fill="#9CDCFE" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                <Ellipse Width="4" Height="4" Fill="#FFD700" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0">
                                                                    <Ellipse.Triggers>
                                                                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                                            <BeginStoryboard>
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                                                       From="0,0,0,0" To="8,0,0,0" Duration="0:0:0.35"/>
