<Window x:Class="XTSPrimeMoverProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XTSPrimeMoverProject"
        xmlns:vm="clr-namespace:XTSPrimeMoverProject.ViewModels"
        mc:Ignorable="d"
        Title="Beckhoff XTS Prime Mover System" Height="900" Width="1400"
        Background="#1E1E1E">
    <Window.Resources>
        <local:MoverPositionConverter x:Key="MoverPositionConverter"/>
        <local:MoverColorConverter x:Key="MoverColorConverter"/>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5,2"/>
        </Style>
        
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,2" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="BECKHOFF XTS PRIME MOVER SYSTEM" 
                               Foreground="#00D4FF" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                    <TextBlock Text="Manufacturing Simulation with 10 Movers, 4 Machines, 4 Robots" 
                               Foreground="#CCCCCC" 
                               FontSize="12"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="START" Command="{Binding StartCommand}" Style="{StaticResource ButtonStyle}"/>
                    <Button Content="STOP" Command="{Binding StopCommand}" Style="{StaticResource ButtonStyle}" Background="#D83B01"/>
                    <Button Content="RESET" Command="{Binding ResetCommand}" Style="{StaticResource ButtonStyle}" Background="#107C10"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>
            
            <!-- XTS Visualization -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="2" CornerRadius="5" Margin="0,0,5,0">
                <Grid>
                    <Canvas x:Name="XTSCanvas" ClipToBounds="True">
                        <!-- XTS Track Circle -->
                        <Ellipse Width="500" Height="500" 
                                 Stroke="#FFD700" 
                                 StrokeThickness="4" 
                                 Fill="Transparent"
                                 Canvas.Left="150" 
                                 Canvas.Top="100"/>
                        
                        <!-- Center Info -->
                        <Border Canvas.Left="350" Canvas.Top="320" Background="#2D2D30" Padding="10" CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="XTS SYSTEM" Style="{StaticResource HeaderTextStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusTextStyle}" HorizontalAlignment="Center" Foreground="#00FF00"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Machine Stations -->
                        <Canvas>
                            <!-- Machine 0 - Top Right -->
                            <Border Canvas.Left="720" Canvas.Top="200" 
                                    Background="#0078D4" 
                                    BorderBrush="#FFFFFF" 
                                    BorderThickness="2" 
                                    CornerRadius="5" 
                                    Width="100" 
                                    Height="80">
                                <StackPanel>
                                    <TextBlock Text="MACHINE 0" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="10"/>
                                    <TextBlock Text="Laser Welder" Foreground="#FFD700" HorizontalAlignment="Center" FontSize="9"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Machine 1 - Bottom Right -->
                            <Border Canvas.Left="720" Canvas.Top="420" 
                                    Background="#0078D4" 
                                    BorderBrush="#FFFFFF" 
                                    BorderThickness="2" 
                                    CornerRadius="5" 
                                    Width="100" 
                                    Height="80">
                                <StackPanel>
                                    <TextBlock Text="MACHINE 1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="10"/>
                                    <TextBlock Text="Assembler" Foreground="#FFD700" HorizontalAlignment="Center" FontSize="9"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Machine 2 - Bottom Left -->
                            <Border Canvas.Left="80" Canvas.Top="420" 
                                    Background="#0078D4" 
                                    BorderBrush="#FFFFFF" 
                                    BorderThickness="2" 
                                    CornerRadius="5" 
                                    Width="100" 
                                    Height="80">
                                <StackPanel>
                                    <TextBlock Text="MACHINE 2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="10"/>
                                    <TextBlock Text="Inspector" Foreground="#FFD700" HorizontalAlignment="Center" FontSize="9"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Machine 3 - Top Left -->
                            <Border Canvas.Left="80" Canvas.Top="200" 
                                    Background="#0078D4" 
                                    BorderBrush="#FFFFFF" 
                                    BorderThickness="2" 
                                    CornerRadius="5" 
                                    Width="100" 
                                    Height="80">
                                <StackPanel>
                                    <TextBlock Text="MACHINE 3" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="10"/>
                                    <TextBlock Text="Tester" Foreground="#FFD700" HorizontalAlignment="Center" FontSize="9"/>
                                </StackPanel>
                            </Border>
                        </Canvas>
                        
                        <!-- Movers (will be positioned dynamically) -->
                        <ItemsControl x:Name="MoversControl" ItemsSource="{Binding Movers, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style>
                                    <Setter Property="Canvas.Left">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource MoverPositionConverter}" ConverterParameter="X" Mode="OneWay">
                                                <Binding Path="Position" Mode="OneWay"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Canvas.Top">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource MoverPositionConverter}" ConverterParameter="Y" Mode="OneWay">
                                                <Binding Path="Position" Mode="OneWay"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Ellipse Width="20" Height="20">
                                            <Ellipse.Fill>
                                                <SolidColorBrush>
                                                    <SolidColorBrush.Color>
                                                        <MultiBinding Converter="{StaticResource MoverColorConverter}" Mode="OneWay">
                                                            <Binding Path="HasPart" Mode="OneWay"/>
                                                            <Binding Path="PartStatus" Mode="OneWay"/>
                                                        </MultiBinding>
                                                    </SolidColorBrush.Color>
                                                </SolidColorBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding MoverId, Mode=OneWay}" 
                                                   Foreground="White" 
                                                   FontSize="10" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Grid>
            </Border>
            
            <!-- Info Panel -->
            <Border Grid.Column="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="2" CornerRadius="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- Production Stats -->
                        <TextBlock Text="PRODUCTION STATISTICS" Style="{StaticResource HeaderTextStyle}"/>
                        <Border Background="#2D2D30" Padding="10" CornerRadius="5" Margin="0,5">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Total Parts: " Style="{StaticResource StatusTextStyle}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalPartsProduced}" Style="{StaticResource StatusTextStyle}" Foreground="#00D4FF"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Good Parts: " Style="{StaticResource StatusTextStyle}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding GoodPartsCount}" Style="{StaticResource StatusTextStyle}" Foreground="#00FF00"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Bad Parts: " Style="{StaticResource StatusTextStyle}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding BadPartsCount}" Style="{StaticResource StatusTextStyle}" Foreground="#FF0000"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Yield: " Style="{StaticResource StatusTextStyle}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding YieldPercentage, StringFormat={}{0:F1}%}" Style="{StaticResource StatusTextStyle}" Foreground="#FFD700"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Movers Status -->
                        <TextBlock Text="MOVERS STATUS" Style="{StaticResource HeaderTextStyle}" Margin="0,15,0,0"/>
                        <ItemsControl ItemsSource="{Binding Movers, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D2D30" Padding="8" Margin="0,2" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock>
                                                <Run Text="Mover " Foreground="#CCCCCC"/>
                                                <Run Text="{Binding MoverId, Mode=OneWay}" Foreground="#00D4FF" FontWeight="Bold"/>
                                                <Run Text=" - " Foreground="#CCCCCC"/>
                                                <Run Text="{Binding State, Mode=OneWay}" Foreground="#FFD700"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding PartStatus, Mode=OneWay, StringFormat='Part: {0}'}" 
                                                       Foreground="#AAAAAA" 
                                                       FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Machines Status -->
                        <TextBlock Text="MACHINES STATUS" Style="{StaticResource HeaderTextStyle}" Margin="0,15,0,0"/>
                        <ItemsControl ItemsSource="{Binding Machines, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D2D30" Padding="8" Margin="0,5" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock>
                                                <Run Text="{Binding Name, Mode=OneWay}" Foreground="#00D4FF" FontWeight="Bold"/>
                                                <Run Text=" (" Foreground="#CCCCCC"/>
                                                <Run Text="{Binding Type, Mode=OneWay}" Foreground="#FFD700"/>
                                                <Run Text=")" Foreground="#CCCCCC"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding CurrentStation, Mode=OneWay, StringFormat='Station: {0}'}" 
                                                       Foreground="#AAAAAA" 
                                                       FontSize="10"/>
                                            <ProgressBar Value="{Binding Progress, Mode=OneWay}" 
                                                         Height="4" 
                                                         Margin="0,3,0,0"
                                                         Background="#3F3F46"
                                                         Foreground="#00FF00"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Robots Status -->
                        <TextBlock Text="ROBOTS STATUS" Style="{StaticResource HeaderTextStyle}" Margin="0,15,0,0"/>
                        <ItemsControl ItemsSource="{Binding Robots, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D2D30" Padding="8" Margin="0,2" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock>
                                                <Run Text="{Binding Name, Mode=OneWay}" Foreground="#00D4FF" FontWeight="Bold"/>
                                                <Run Text=" → M" Foreground="#CCCCCC"/>
                                                <Run Text="{Binding AssignedMachine, Mode=OneWay}" Foreground="#FFD700"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding State, Mode=OneWay}" 
                                                       Foreground="#AAAAAA" 
                                                       FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        
        <!-- Footer -->
        <Border Grid.Row="2" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,2,0,0" Padding="10">
            <TextBlock Text="Beckhoff XTS Simulation - Prime Mover Manufacturing System" 
                       Foreground="#888888" 
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
