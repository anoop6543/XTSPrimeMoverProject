                        </StackPanel>
                    </TabItem.Header>
                    <ContentPresenter Content="{Binding Machines[0], Mode=OneWay}"
                                      ContentTemplate="{StaticResource MachineDetailTemplate}"/>
                </TabItem>

                <TabItem Style="{StaticResource DarkTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔧 " FontSize="11"/>
                            <TextBlock Text="{Binding Machines[1].Name, Mode=OneWay}" FontSize="11"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ContentPresenter Content="{Binding Machines[1], Mode=OneWay}"
                                      ContentTemplate="{StaticResource MachineDetailTemplate}"/>
                </TabItem>

                <TabItem Style="{StaticResource DarkTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍 " FontSize="11"/>
                            <TextBlock Text="{Binding Machines[2].Name, Mode=OneWay}" FontSize="11"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ContentPresenter Content="{Binding Machines[2], Mode=OneWay}"
                                      ContentTemplate="{StaticResource MachineDetailTemplate}"/>
                </TabItem>

                <TabItem Style="{StaticResource DarkTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧪 " FontSize="11"/>
                            <TextBlock Text="{Binding Machines[3].Name, Mode=OneWay}" FontSize="11"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ContentPresenter Content="{Binding Machines[3], Mode=OneWay}"
