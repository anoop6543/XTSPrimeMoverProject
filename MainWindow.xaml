                                            <ItemsControl ItemsSource="{Binding Stations, Mode=OneWay}" Width="120" Height="120" RenderTransformOrigin="0.5,0.5">
                                                <ItemsControl.RenderTransform><RotateTransform Angle="{Binding RotaryAngle, Mode=OneWay}"/></ItemsControl.RenderTransform>
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle><Style><Setter Property="Canvas.Left"><Setter.Value><MultiBinding Converter="{StaticResource StationRotaryPositionConverter}" ConverterParameter="X" Mode="OneWay"><Binding Path="StationIndex" Mode="OneWay"/><Binding Path="StationCount" Mode="OneWay"/></MultiBinding></Setter.Value></Setter><Setter Property="Canvas.Top"><Setter.Value><MultiBinding Converter="{StaticResource StationRotaryPositionConverter}" ConverterParameter="Y" Mode="OneWay"><Binding Path="StationIndex" Mode="OneWay"/><Binding Path="StationCount" Mode="OneWay"/></MultiBinding></Setter.Value></Setter></Style></ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate><DataTemplate><Ellipse Width="14" Height="14" Stroke="#E6E6E6" StrokeThickness="1"><Ellipse.Fill><SolidColorBrush><SolidColorBrush.Color><MultiBinding Converter="{StaticResource StationStateBrushConverter}" Mode="OneWay"><Binding Path="Status" Mode="OneWay"/><Binding Path="IsCurrentIndex" Mode="OneWay"/><Binding Path="HasPart" Mode="OneWay"/></MultiBinding></SolidColorBrush.Color></SolidColorBrush></Ellipse.Fill></Ellipse></DataTemplate></ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Canvas>
                                    </StackPanel>
                                </Border>
                            </Canvas>

                            <ItemsControl x:Name="RobotTransferOverlayControl" ItemsSource="{Binding Robots, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style>
                                        <Setter Property="Canvas.Left" Value="{Binding CanvasX, Mode=OneWay}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding CanvasY, Mode=OneWay}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="28" Height="28">
                                            <Ellipse Width="28" Height="28" Stroke="#00D4FF" StrokeThickness="2" Fill="#1F1F20" Opacity="0.95"/>
                                            <TextBlock Text="🤖" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CanvasTransferLabel, Mode=OneWay}"
                                                       Foreground="#9CDCFE"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Margin="16,-8,0,0"
                                                       TextWrapping="Wrap"
                                                       Width="120"
                                                       Visibility="{Binding ShowTransferLabel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl x:Name="RobotTransferDashedLinesControl" ItemsSource="{Binding Robots, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas Width="1040" Height="760"
                                                Visibility="{Binding IsTransferPathVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Line X1="{Binding TransferFromX, Mode=OneWay}"
                                                  Y1="{Binding TransferFromY, Mode=OneWay}"
                                                  X2="{Binding TransferToX, Mode=OneWay}"
                                                  Y2="{Binding TransferToY, Mode=OneWay}"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="4,3"
                                                  Opacity="0.9">
                                                <Line.Stroke>
                                                    <Binding Path="TransferPathColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                                </Line.Stroke>
                                                <Line.Effect>
                                                    <DropShadowEffect Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.85"/>
                                                </Line.Effect>
                                                <Line.Style>
                                                    <Style TargetType="Line">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTransferPathVisible, Mode=OneWay}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard x:Name="TransferDashStoryboard">
                                                                        <Storyboard RepeatBehavior="Forever">
                                                                            <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset" From="0" To="-18" Duration="0:0:0.45"/>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.45" To="1.0" Duration="0:0:0.2" AutoReverse="True" RepeatBehavior="Forever"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="TransferDashStoryboard"/>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Line.Style>
                                            </Line>

                                            <Polygon Points="{Binding TransferArrowPoints, Mode=OneWay}"
                                                     StrokeThickness="1"
                                                     Opacity="0.95">
                                                <Polygon.Fill>
                                                    <Binding Path="TransferPathColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                                </Polygon.Fill>
                                                <Polygon.Stroke>
                                                    <Binding Path="TransferPathColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                                </Polygon.Stroke>
                                                <Polygon.Effect>
                                                    <DropShadowEffect Color="#00D4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                                </Polygon.Effect>
                                            </Polygon>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl x:Name="MoversControl" ItemsSource="{Binding Movers, Mode=OneWay}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style>
                                        <Setter Property="Canvas.Left"><Setter.Value><MultiBinding Converter="{StaticResource MoverPositionConverter}" ConverterParameter="X" Mode="OneWay"><Binding Path="Position" Mode="OneWay"/></MultiBinding></Setter.Value></Setter>
                                        <Setter Property="Canvas.Top"><Setter.Value><MultiBinding Converter="{StaticResource MoverPositionConverter}" ConverterParameter="Y" Mode="OneWay"><Binding Path="Position" Mode="OneWay"/></MultiBinding></Setter.Value></Setter>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ToolTip="{Binding TrackingNumber, Mode=OneWay}">
                                            <Ellipse Width="20" Height="20">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush>
                                                        <SolidColorBrush.Color>
                                                            <MultiBinding Converter="{StaticResource MoverColorConverter}" Mode="OneWay">
                                                                <Binding Path="HasPart" Mode="OneWay"/>
                                                                <Binding Path="PartStatus" Mode="OneWay"/>
                                                            </MultiBinding>
                                                        </SolidColorBrush.Color>
                                                    </SolidColorBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding MoverId, Mode=OneWay}" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ShortTrackingNumber, Mode=OneWay}" Foreground="#9CDCFE" FontSize="7" Margin="0,18,0,0" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </Grid>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!-- ════════════════════════════════════
                     PER-MACHINE ENHANCED TABS  (4 tabs)
                ════════════════════════════════════ -->
                <TabItem Style="{StaticResource DarkTabItemStyle}">
