                <TabItem Header="DB Tables Viewer">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="RUNTIME DATABASE TABLES" Style="{StaticResource HeaderTextStyle}"/>
                            <DockPanel Margin="0,6,0,0">
                                <ComboBox Width="220"
                                          ItemsSource="{Binding DbTables, Mode=OneWay}"
                                          SelectedItem="{Binding SelectedDbTable, Mode=TwoWay}"
                                          Margin="0,0,8,0"/>
                                <Button Content="Refresh Tables"
                                        Command="{Binding RefreshDbTablesCommand}"
                                        Style="{StaticResource ButtonStyle}"
                                        Padding="12,6"
                                        Margin="0"
                                        Width="130"/>
                            </DockPanel>
                            <TextBox Margin="0,6,0,0"
                                     Height="28"
                                     Text="{Binding DbTableSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="#F0F0F0"
                                     Background="#1F1F20"
                                     BorderBrush="#3F3F46"
                                     BorderThickness="1"
                                     VerticalContentAlignment="Center"
                                     Padding="6,0"
                                     ToolTip="Quick filter across all columns"/>
                            <TextBlock Text="{Binding DbTableStatus, Mode=OneWay}" Foreground="#9CDCFE" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                              ItemsSource="{Binding DbTableRowsView, Mode=OneWay}"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="0,10,0,0"
                              HeadersVisibility="All"
                              GridLinesVisibility="All"
                              SelectionUnit="FullRow"
                              FrozenColumnCount="1"
                              ColumnWidth="SizeToHeader"
                              MinColumnWidth="110"
                              Style="{StaticResource DarkDataGridStyle}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2D2D30"/>
                                    <Setter Property="Foreground" Value="#FFD700"/>
                                    <Setter Property="BorderBrush" Value="#3F3F46"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="#1F1F20"/>
                                    <Setter Property="Foreground" Value="#F0F0F0"/>
                                    <Setter Property="BorderBrush" Value="#3F3F46"/>
                                    <Setter Property="BorderThickness" Value="0.5"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#1F1F20"/>
                                    <Setter Property="Foreground" Value="#F0F0F0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#094771"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Orchestration Editor">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="SAFE ORCHESTRATION EDITOR" Style="{StaticResource HeaderTextStyle}"/>
                            <TextBlock Text="Edit machine order, then apply only when simulation is stopped. Interlocks enforce safe apply gates." Foreground="#AAAAAA" FontSize="10" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding OrchestrationStatus, Mode=OneWay}" Foreground="#9CDCFE" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding OrchestrationValidationStatus, Mode=OneWay}" Foreground="#DCDCAA" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OrchestrationSteps, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False"
                                  CanUserAddRows="False"
                                  Margin="0,10,0,10"
                                  Style="{StaticResource DarkDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Step" Binding="{Binding OrderText, Mode=OneWay}" Width="80"/>
                                <DataGridTextColumn Header="Machine ID" Binding="{Binding MachineId, Mode=OneWay}" Width="90"/>
                                <DataGridTextColumn Header="Machine" Binding="{Binding MachineName, Mode=OneWay}" Width="*"/>
                                <DataGridTemplateColumn Header="Output Status" Width="170">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OutputStatus, Mode=OneWay}" Foreground="#F0F0F0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.OrchestrationOutputStatusOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                      SelectedItem="{Binding OutputStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource DarkComboBoxStyle}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Move" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="↑"
                                                        Width="36"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.MoveOrchestrationStepUpCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ButtonStyle}"
                                                        Padding="4,2"/>
                                                <Button Content="↓"
                                                        Width="36"
                                                        Command="{Binding DataContext.MoveOrchestrationStepDownCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ButtonStyle}"
                                                        Padding="4,2"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="SAFETY GATES" Foreground="#FFD700" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding SafetyGates, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="3" Padding="6" Margin="0,1">
                                            <DockPanel>
                                                <TextBlock Text="●" Foreground="{Binding GateColor, Mode=OneWay}" FontSize="14" Margin="0,0,6,0"/>
                                                <StackPanel>
                                                    <TextBlock>
                                                        <Run Text="{Binding GateName, Mode=OneWay}" Foreground="#F0F0F0" FontWeight="SemiBold"/>
                                                        <Run Text=" - " Foreground="#888"/>
                                                        <Run Text="{Binding GateStateText, Mode=OneWay}" Foreground="{Binding GateColor, Mode=OneWay}" FontWeight="Bold"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Detail, Mode=OneWay}" Foreground="#AAAAAA" FontSize="10" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <DockPanel Margin="0,8,0,0">
                                <Button Content="Reload Current"
                                        Command="{Binding ReloadOrchestrationCommand}"
                                        Style="{StaticResource ButtonStyle}"
                                        Padding="12,6"
                                        Margin="0,0,8,0"
                                        Width="130"/>
                                <Button Content="Preview Validation"
                                        Command="{Binding PreviewOrchestrationValidationCommand}"
                                        Style="{StaticResource ButtonStyle}"
                                        Padding="12,6"
                                        Margin="0,0,8,0"
                                        Width="160"/>
                                <Button Content="Refresh Safety Gates"
                                        Command="{Binding RefreshSafetyGatesCommand}"
                                        Style="{StaticResource ButtonStyle}"
                                        Padding="12,6"
                                        Margin="0,0,8,0"
                                        Width="170"/>
                                <Button Content="Apply Orchestration"
                                        Command="{Binding ApplyOrchestrationCommand}"
                                        Style="{StaticResource ButtonStyle}"
                                        Padding="12,6"
                                        Margin="0"
                                        Width="170"/>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Part History Inspector">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="PART HISTORY HELP: enter a tracking number like TRK-00001 (see mover labels/logs)." Foreground="#DCDCAA" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <DockPanel>
                                <TextBox Width="170" Text="{Binding PartHistoryTrackingNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0" VerticalContentAlignment="Center" Style="{StaticResource DarkTextBoxStyle}"/>
                                <Button Content="Inspect" Command="{Binding InspectPartHistoryCommand}" Style="{StaticResource ButtonStyle}" Padding="12,6" Margin="0" Width="90"/>
                            </DockPanel>
                            <TextBlock Text="{Binding PartHistoryStatus, Mode=OneWay}" Foreground="#9CDCFE" FontSize="11" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding PartHistorySummary, Mode=OneWay}" Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding PartHistoryEvents, Mode=OneWay}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,10,0,10" Style="{StaticResource DarkDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding EventTime, Mode=OneWay}" Width="130"/>
                                <DataGridTextColumn Header="Event" Binding="{Binding EventType, Mode=OneWay}" Width="110"/>
                                <DataGridTextColumn Header="Location" Binding="{Binding Location, Mode=OneWay}" Width="110"/>
                                <DataGridTextColumn Header="Details" Binding="{Binding Details, Mode=OneWay}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Background="#2D2D30" Padding="8" CornerRadius="4">
                            <DockPanel>
                                <ComboBox Width="170" ItemsSource="{Binding ExportTables, Mode=OneWay}" SelectedItem="{Binding SelectedExportTable, Mode=TwoWay}" Margin="0,0,6,0" Style="{StaticResource DarkComboBoxStyle}"/>
                                <Button Content="Export Selected Table" Command="{Binding ExportCsvCommand}" Style="{StaticResource ButtonStyle}" Padding="12,6" Margin="0" Width="170"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <Border Grid.Column="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="2" CornerRadius="5">
                <TabControl Style="{StaticResource DarkTabControlStyle}" BorderThickness="0" ItemContainerStyle="{StaticResource DarkTabItemStyle}">
                    <TabItem Header="Line HMI">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <TextBlock Text="PRODUCTION STATISTICS" Style="{StaticResource HeaderTextStyle}"/>
                                <Border Background="#2D2D30" Padding="10" CornerRadius="5" Margin="0,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PrimeMoverEnteredCount, Mode=OneWay, StringFormat='Prime Mover Entered: {0}'}" Style="{StaticResource StatusTextStyle}"/>
                                        <TextBlock Text="{Binding PrimeMoverExitedCount, Mode=OneWay, StringFormat='Prime Mover Exited: {0}'}" Style="{StaticResource StatusTextStyle}"/>
                                        <TextBlock Text="{Binding GoodPartsCount, Mode=OneWay, StringFormat='Good Parts: {0}'}" Style="{StaticResource StatusTextStyle}"/>
                                        <TextBlock Text="{Binding BadPartsCount, Mode=OneWay, StringFormat='Bad Parts: {0}'}" Style="{StaticResource StatusTextStyle}"/>
                                        <TextBlock Text="{Binding YieldPercentage, Mode=OneWay, StringFormat='Yield: {0:F1}%'}" Style="{StaticResource StatusTextStyle}"/>
                                        <TextBlock Text="{Binding GatewayModeStatus, Mode=OneWay}" Foreground="#9CDCFE" FontSize="11" FontWeight="SemiBold" Margin="5,4,5,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding DatabasePath, Mode=OneWay, StringFormat='DB: {0}'}" Foreground="#AAAAAA" FontSize="10" Margin="5,4,5,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="COLOR + FLOW LEGEND" Style="{StaticResource HeaderTextStyle}" Margin="0,10,0,0"/>
                                <Border Background="#2D2D30" Padding="8" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Foreground="#CCCCCC" FontSize="10" Text="Yellow = BaseLayer (new part loaded, waiting for first machine)"/>
                                        <TextBlock Foreground="#CCCCCC" FontSize="10" Text="Orange = InProcess (between operations)"/>
                                        <TextBlock Foreground="#CCCCCC" FontSize="10" Text="Cyan = Assembled / intermediate stage"/>
                                        <TextBlock Foreground="#CCCCCC" FontSize="10" Text="Green = Good (final pass, exiting)"/>
                                        <TextBlock Foreground="#CCCCCC" FontSize="10" Text="Red = Bad (rejected/fault outcome)"/>
                                        <TextBlock Foreground="#AAAAAA" FontSize="10" Margin="0,4,0,0" Text="AtLoadStation=waiting at machine interface; Loaded=queued behind upstream mover; AtUnloadStation=waiting for machine output transfer." TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="MOVER LIVE EXPLAINER" Style="{StaticResource HeaderTextStyle}" Margin="0,10,0,0"/>
                                <ItemsControl ItemsSource="{Binding Movers, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2D2D30" Padding="6" Margin="0,2" CornerRadius="3" BorderBrush="#3F3F46" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock>
                                                        <Run Text="Mover " Foreground="#CCCCCC"/>
                                                        <Run Text="{Binding MoverId, Mode=OneWay}" Foreground="#00D4FF" FontWeight="Bold"/>
                                                        <Run Text=" | " Foreground="#777"/>
                                                        <Run Text="{Binding State, Mode=OneWay}" Foreground="#FFD700"/>
                                                        <Run Text=" | Pos " Foreground="#777"/>
                                                        <Run Text="{Binding PositionDeg, Mode=OneWay}" Foreground="#B5CEA8"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding TrackingNumber, Mode=OneWay, StringFormat='Part: {0}'}" Foreground="#9CDCFE" FontSize="10"/>
                                                    <TextBlock Text="{Binding PartStatus, Mode=OneWay, StringFormat='Part State: {0}'}" Foreground="#CCCCCC" FontSize="10"/>
                                                    <TextBlock Text="{Binding NextMachine, Mode=OneWay, StringFormat='Next Target: {0}'}" Foreground="#DCDCAA" FontSize="10"/>
                                                    <TextBlock Text="{Binding TargetStation, Mode=OneWay, StringFormat='Dock Target: {0}'}" Foreground="#D7BA7D" FontSize="10"/>
                                                    <TextBlock Text="{Binding FlowMeaning, Mode=OneWay, StringFormat='Meaning: {0}'}" Foreground="#B5CEA8" FontSize="10" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding WaitReason, Mode=OneWay, StringFormat='Wait/Move: {0}'}" Foreground="#CE9178" FontSize="10" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="MACHINE RUNTIME TRACKING" Style="{StaticResource HeaderTextStyle}" Margin="0,10,0,0"/>
                                <ItemsControl ItemsSource="{Binding Machines, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2D2D30" Padding="8" Margin="0,3" CornerRadius="3" BorderBrush="#3F3F46" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock>
                                                        <Run Text="{Binding Name, Mode=OneWay}" Foreground="#00D4FF" FontWeight="Bold"/>
                                                        <Run Text=" | PLC: " Foreground="#777"/>
                                                        <Run Text="{Binding SequencerState, Mode=OneWay}" Foreground="#FFD700"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding RuntimeAction, Mode=OneWay, StringFormat='Action: {0}'}" Foreground="#9CDCFE" FontSize="10"/>
                                                    <TextBlock Text="{Binding CurrentStation, Mode=OneWay, StringFormat='Station: {0}'}" Foreground="#CCCCCC" FontSize="10"/>
                                                    <TextBlock Text="{Binding CurrentPartId, Mode=OneWay, StringFormat='Part: {0}'}" Foreground="#B5CEA8" FontSize="10"/>
                                                    <TextBlock Text="{Binding CurrentStationEtPt, Mode=OneWay}" Foreground="#CE9178" FontSize="10"/>
                                                    <TextBlock Text="{Binding FaultMessage, Mode=OneWay, StringFormat='Fault: {0}'}" Foreground="#CE9178" FontSize="10" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="ROBOT TRANSFERS (MOVER ↔ MACHINE)" Style="{StaticResource HeaderTextStyle}" Margin="0,10,0,0"/>
                                <ItemsControl ItemsSource="{Binding Robots, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2D2D30" Padding="8" Margin="0,2" CornerRadius="3" BorderBrush="#3F3F46" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock>
                                                            <Run Text="{Binding Name, Mode=OneWay}" Foreground="#00D4FF" FontWeight="Bold"/>
                                                            <Run Text="  |  M" Foreground="#CCCCCC"/>
                                                            <Run Text="{Binding AssignedMachine, Mode=OneWay}" Foreground="#FFD700"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding TransferLane, Mode=OneWay, StringFormat='Lane: {0}'}" Foreground="#DCDCAA" FontSize="10"/>
                                                        <TextBlock Text="{Binding TransferStage, Mode=OneWay, StringFormat='Stage: {0}'}" Foreground="#CE9178" FontSize="10"/>
                                                        <TextBlock Text="{Binding HeldTrackingNumber, Mode=OneWay, StringFormat='Part in gripper: {0}'}" Foreground="#9CDCFE" FontSize="10"/>
                                                        <TextBlock Text="{Binding TransferProgressText, Mode=OneWay}" Foreground="#B5CEA8" FontSize="10"/>
                                                        <ProgressBar Value="{Binding Progress, Mode=OneWay}" Height="6" Margin="0,4,0,0" Background="#3F3F46" Foreground="#00B7C3"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="1" CornerRadius="6" Padding="10,6" Margin="10,0,0,0" VerticalAlignment="Top">
                                                        <Border.Background>
                                                            <Binding Path="TransferBadgeColor" Mode="OneWay" Converter="{StaticResource StringToBrushConverter}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding TransferBadgeText, Mode=OneWay}" Foreground="White" FontWeight="Bold" FontSize="9"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="WATCHDOG STATUS" Style="{StaticResource HeaderTextStyle}" Margin="0,10,0,0"/>
                                <ItemsControl ItemsSource="{Binding WatchdogStatuses, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2D2D30" Padding="8" Margin="0,3" CornerRadius="3" BorderBrush="#3F3F46" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock><Run Text="Code: "/><Run Text="{Binding Code, Mode=OneWay}"/><Run Text=" | Count: "/><Run Text="{Binding TriggerCount, Mode=OneWay}"/></TextBlock>
                                                    <TextBlock><Run Text="Last Trigger: "/><Run Text="{Binding LastTriggeredAtText, Mode=OneWay}"/><Run Text=" | Last Object: "/><Run Text="{Binding LastRecoveredObject, Mode=OneWay}"/></TextBlock>
                                                    <TextBlock Text="{Binding LastMessage, Mode=OneWay, StringFormat='Message: {0}'}" Foreground="#AAAAAA" FontSize="10" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#1F1F20" BorderBrush="#3F3F46" BorderThickness="0,2,0,0" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="EXECUTION LOGGER" Foreground="#FFD700" FontWeight="Bold" Margin="2,0,0,6"/>
                <ListBox x:Name="ExecutionLogListBox" Grid.Row="1" ItemsSource="{Binding ExecutionLogs, Mode=OneWay}" Background="#252526" Foreground="#DCDCDC" BorderBrush="#3F3F46" BorderThickness="1" FontFamily="Consolas" FontSize="11" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,2,0,0" Padding="10">
            <TextBlock Text="Beckhoff XTS Simulation - Prime Mover Manufacturing System" Foreground="#888888" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
